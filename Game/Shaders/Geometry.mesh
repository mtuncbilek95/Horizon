#version 460
#extension GL_EXT_mesh_shader : require

#define MAX_TRIANGLES 126
#define MAX_VERTICES 64

layout(local_size_x = 128) in;
layout(triangles, max_vertices = MAX_VERTICES, max_primitives = MAX_TRIANGLES) out;

struct Vertex
{
    vec4 position;
    vec4 normal;
    vec4 tangent;
    vec2 uv;
    vec2 padding;
};

struct Meshlet
{
    uint vertices[64];
    uint indices[378];
    uint vertexCount;
    uint indexCount;
};

struct TaskPayload
{
    uint meshletID;
    uint lodLevel;
};

taskPayloadSharedEXT TaskPayload payload;

layout(set = 0, binding = 0) readonly buffer MeshletBufferLOD0 { Meshlet meshlets[]; } lod0;
layout(set = 0, binding = 1) readonly buffer MeshletBufferLOD1 { Meshlet meshlets[]; } lod1;
layout(set = 0, binding = 2) readonly buffer MeshletBufferLOD2 { Meshlet meshlets[]; } lod2;
layout(set = 0, binding = 3) readonly buffer VertexBuffer      { Vertex  vertices[]; };

layout(push_constant) uniform PushData
{
    mat4  model;
    mat4  viewProj;
    vec4  cameraPos;
    float lodDistance0;
    float lodDistance1;
    float lodDistance2;
    float padding;
} pushConst;

layout(location = 0) perprimitiveEXT flat out uint outMeshletID[];
layout(location = 1) perprimitiveEXT flat out uint outLodLevel[];

void main()
{
    uint meshletID  = payload.meshletID;
    uint localIndex = gl_LocalInvocationID.x;

    Meshlet currentMeshlet;
    if(payload.lodLevel == 0)
        currentMeshlet = lod0.meshlets[meshletID];
    else if(payload.lodLevel == 1)
        currentMeshlet = lod1.meshlets[meshletID];
    else
        currentMeshlet = lod2.meshlets[meshletID];

    uint triCount = currentMeshlet.indexCount / 3;
    uint vtxCount = currentMeshlet.vertexCount;

    if(localIndex == 0)
        SetMeshOutputsEXT(vtxCount, triCount);

    if(localIndex < vtxCount)
    {
        uint globalVertexIndex = currentMeshlet.vertices[localIndex];
        vec4 localPos = pushConst.model * vec4(vertices[globalVertexIndex].position.xyz, 1.0);
        gl_MeshVerticesEXT[localIndex].gl_Position = pushConst.viewProj * localPos;
    }

    if(localIndex < triCount)
    {
        uint i0 = currentMeshlet.indices[localIndex * 3 + 0];
        uint i1 = currentMeshlet.indices[localIndex * 3 + 1];
        uint i2 = currentMeshlet.indices[localIndex * 3 + 2];

        gl_PrimitiveTriangleIndicesEXT[localIndex] = uvec3(i0, i1, i2);
        outMeshletID[localIndex] = meshletID;
        outLodLevel[localIndex]  = payload.lodLevel;
    }
}