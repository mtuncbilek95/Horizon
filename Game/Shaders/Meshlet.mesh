#version 460
#extension GL_EXT_mesh_shader : require

#define MAX_TRIANGLES 64
#define MAX_VERTICES (MAX_TRIANGLES * 3)

layout(local_size_x = MAX_TRIANGLES) in;
layout(triangles, max_vertices = MAX_VERTICES, max_primitives = MAX_TRIANGLES) out;

struct Vertex 
{
    vec4 position;
    vec4 normal;
    vec4 tangent;
    vec2 uv;
    vec2 padding;
};

layout(set = 0, binding = 0) readonly buffer VertexBuffer { Vertex vertices[]; };
layout(set = 0, binding = 1) readonly buffer IndexBuffer { uint indices[]; };

layout(push_constant) uniform PushData
{
    mat4 model;
    mat4 viewProj;
    uint triangleCount;
} pushConst;

layout(location = 0) flat out uint outMeshletID[];

void main()
{
    uint cubeID = gl_WorkGroupID.x;
    uint localTriIndex = gl_LocalInvocationID.x;

    if(localTriIndex == 0) {
        SetMeshOutputsEXT(pushConst.triangleCount * 2, pushConst.triangleCount);
    }

    if(localTriIndex < pushConst.triangleCount)
    {
        uint i0 = indices[localTriIndex * 3 + 0];
        uint i1 = indices[localTriIndex * 3 + 1];
        uint i2 = indices[localTriIndex * 3 + 2];

        uint v0 = localTriIndex * 3 + 0;
        uint v1 = localTriIndex * 3 + 1;
        uint v2 = localTriIndex * 3 + 2;

        float gridX = float(cubeID % 100) * 2.5; 
        float gridZ = float(cubeID / 100) * 2.5;
        vec3 instanceOffset = vec3(gridX - 125.0, 0.0, gridZ - 125.0);

        vec4 localPos0 = pushConst.model * vec4(vertices[i0].position.xyz, 1.0);
        vec4 localPos1 = pushConst.model * vec4(vertices[i1].position.xyz, 1.0);
        vec4 localPos2 = pushConst.model * vec4(vertices[i2].position.xyz, 1.0);

        gl_MeshVerticesEXT[v0].gl_Position = pushConst.viewProj * vec4(localPos0.xyz + instanceOffset, 1.0);
        gl_MeshVerticesEXT[v1].gl_Position = pushConst.viewProj * vec4(localPos1.xyz + instanceOffset, 1.0);
        gl_MeshVerticesEXT[v2].gl_Position = pushConst.viewProj * vec4(localPos2.xyz + instanceOffset, 1.0);

        uint uniqueID = (cubeID * pushConst.triangleCount) + localTriIndex;
        outMeshletID[v0] = uniqueID;
        outMeshletID[v1] = uniqueID;
        outMeshletID[v2] = uniqueID;

        gl_PrimitiveTriangleIndicesEXT[localTriIndex] = uvec3(v0, v1, v2);
    }
}